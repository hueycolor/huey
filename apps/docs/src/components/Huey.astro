---
const { size = 32, ...rest } = Astro.props
---
<script>
  const huey = document.querySelector('#hero-mascot')
  const wheel = huey?.querySelector('[huey-wheel]')
  
  window.addEventListener('huey:celebrate', () => {
    wheel?.classList.add('celebrate')

    setTimeout(() => wheel?.classList.remove('celebrate'), 7000)
  })
</script>


