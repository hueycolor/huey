---
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro'
import Default from '@astrojs/starlight/components/Sidebar.astro'
import Search from '@astrojs/starlight/components/Search.astro'
import Logomark from '@/components/Logomark.astro'
import FrameworkPicker from '@/components/FrameworkPicker.astro'
---

<div class="aj-sidebar aj-custom">
  <div class="top">
    <div class="sidebar-header">
      <Logomark />
      <SocialIcons />
    </div>
    <Search />
    <FrameworkPicker />
  </div>
  <div class="center">
    <Default>
      <slot />
    </Default>
  </div>
</div>

<style>
  .aj-sidebar {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    height: 100%;

    & > * {
      width: var(--sl-toc-width);
    }

    .top {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-12);
      padding: var(--spacing-16);
      padding-bottom: var(--spacing-8);

      .sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-inline-end: var(--spacing-4);
      }

      button[data-open-modal] {
        background-color: var(--color-linen-100);
        border-color: var(--color-linen-200);
        color: var(--color-stone-950);

        & > kbd {
          background-color: var(--color-beige-100);
          border: 1px solid var(--color-linen-200);
        }
      }

      dialog {
        background-color: var(--color-linen-100);
        border: 1px solid var(--color-linen-200);
        color: var(--color-stone-950);
      }
    }

    .center {
      overflow-y: auto;
      padding: var(--spacing-16);
      overflow-x: hidden;
      min-height: 0;
      flex: 1;
    }
  }
</style>
