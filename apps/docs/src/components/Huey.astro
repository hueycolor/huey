<style>
  [huey-mascot] {
    transition: all 300ms ease-in-out;
    &:hover {
      [huey-eyes] {
        animation-name: none;
      }

      [huey-eyelids] {
        transform: translate(0, 6px);
      }
    }
  }

  [huey-mouth] {
    transition: all 200ms
      linear(0, 0.324 9.1%, 0.584 18.6%, 0.782 28.6%, 0.858 33.8%, 0.92 39.2%, 0.997 49.5%, 1.021 55.1%, 1.033 61%, 1.035 71.7%, 1);
  }

  [huey-mascot]:has([huey-wheel].celebrate) {
    & {
      /* Add jumb animation */
    }

    [huey-eyes] {
      animation-name: none;
    }

    [huey-eyelids] {
      transform: translate(0, 6px);
    }

    [huey-mouth] {
      transform: translateY(-1px);
    }
  }

  [huey-wheel].celebrate {

    /*
      stop blinking
      eyesmile
      mouth tucks a bit -1px/y
      squish a bit
      jumb 100px high
      unsquish

    */
    animation: spin 1.5s cubic-bezier(0.33, 1, 0.68, 1);
  }

  [huey-wheel] {
    transform-origin: 40.64px 40.64px;
  }

  [huey-eyes] {
    transform-origin: 50% 50%;
    animation: blink 4s 1s ease-in-out infinite;
    ani
  }

  [huey-eyelids] {
    transition: all 200ms
      linear(0, 0.324 9.1%, 0.584 18.6%, 0.782 28.6%, 0.858 33.8%, 0.92 39.2%, 0.997 49.5%, 1.021 55.1%, 1.033 61%, 1.035 71.7%, 1);
    transform: translate(0, 10px);
  }

  @keyframes blink {
    0%,
    100% {
      transform: scaleY(1);
    }

    /* First blink */
    2% {
      transform: scaleY(0);
    }

    4% {
      transform: scaleY(1);
    }

    /* Second blink */
    6% {
      transform: scaleY(0);
    }

    8% {
      transform: scaleY(1);
    }

    /* Stay open for the rest of timeframe */
  }
  
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
