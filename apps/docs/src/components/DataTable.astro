---
interface Props {
  headers: string[]
  rows: string[][]
}

const { headers, rows } = Astro.props

function cellHtml(value: string): string {
  const escaped = value.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  return escaped.replace(/`([^`]+)`/g, '<code>$1</code>')
}
---

<div class="data-table-wrapper">
  <table class="data-table">
    <thead>
      <tr>
        {headers.map((h) => <th>{h}</th>)}
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            {row.map((cell) => (
              <td>
                <Fragment set:html={cellHtml(cell)} />
              </td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  .data-table-wrapper {
    overflow-x: auto;
    border: 1px solid color-mix(in srgb, var(--color-linen-950) 10%, transparent);
    border-radius: var(--radius-12);
    margin-block: var(--spacing-16);
  }

  .data-table {
    display: table;
    width: 100%;
    border-collapse: collapse;
    font: var(--paragraph-sm);
    color: var(--color-stone-950);
  }

  .data-table thead {
    display: table-header-group;
    background-color: var(--color-linen-100);
  }

  .data-table tbody {
    display: table-row-group;
  }

  .data-table tr {
    display: table-row;
  }

  .data-table th,
  .data-table td {
    display: table-cell;
  }

  .data-table th {
    text-align: left;
    font: var(--label-xs);
    text-transform: uppercase;
    color: var(--color-stone-600);
    padding: var(--spacing-10) var(--spacing-16);
    border-bottom: 1px solid color-mix(in srgb, var(--color-linen-950) 10%, transparent);
  }

  .data-table td {
    padding: var(--spacing-10) var(--spacing-16);
    border-bottom: 1px solid color-mix(in srgb, var(--color-linen-950) 6%, transparent);
    vertical-align: top;
  }

  .data-table tbody tr:last-child td {
    border-bottom: none;
  }

  .data-table :global(code) {
    font: var(--docs-xs);
    background-color: color-mix(in srgb, var(--color-linen-950) 5%, transparent);
    padding: var(--spacing-2) var(--spacing-6);
    border-radius: var(--radius-4);
    white-space: nowrap;
  }
</style>
