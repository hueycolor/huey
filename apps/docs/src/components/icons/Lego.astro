<style is:global>
  [data-icon='lego'] {
    overflow: unset;
  }

  [data-piece] {
    transition: transform 250ms ease-out;
  }

  [data-piece='top'] {
    transition:
      transform 250ms ease-out,
      opacity 250ms ease-out;
  }

  .feature:hover [data-icon='lego'] [data-piece] {
    transition: transform 250ms cubic-bezier(1, 0.015, 0.001, 1);
  }

  .feature:hover [data-icon='lego'] [data-piece='top'] {
    transition:
      transform 250ms cubic-bezier(1, 0.015, 0.001, 1),
      opacity 250ms ease-out;
    opacity: 1;
  }

  .feature:hover [data-icon='lego'] [data-piece='bottom'] {
    transition-delay: 100ms;
  }

  [data-piece='top'] {
    transform: translateY(-40px);
    opacity: 0;
  }

  .feature:hover [data-icon='lego'] {
    [data-piece='top'] {
      transform: translateY(-14px);
    }
    [data-piece='bottom'] {
      transform: translateY(1px);
    }
  }
</style>
