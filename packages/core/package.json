{
  "name": "@hueycolor/core",
  "type": "module",
  "version": "0.0.1-beta.1",
  "private": false,
  "description": "Core utility lib for color manipulation for huey's components",
  "author": "Eihab Khan <yo@eihab.me>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hueycolor/huey",
    "directory": "packages/core"
  },
  "keywords": [
    "color",
    "colour",
    "color-manipulation",
    "hsl",
