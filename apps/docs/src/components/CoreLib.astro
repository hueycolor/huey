---
import CoreLibSnippets from '@/components/CoreLibSnippets.vue'
import CoreLibCodePreview from '@/components/CoreLibCodePreview.vue'
import SectionHeading from '@/components/SectionHeading.astro'
import AppIcon from '@/components/AppIcon.vue'
---

<section class="core-lib" data-size="wide">
  <div class="info">
    <SectionHeading color="var(--color-neutral-50)">
      <Fragment slot="title">Not Just UI</Fragment>
      <Fragment slot="description">Huey also offers a <u>framework-agnostic utility library</u> for color manipulation</Fragment>
    </SectionHeading>
    <CoreLibSnippets client:load />
    <a hc-button href="/overview/core/" data-variant="primary">
      Explore the Core
      <AppIcon icon="ph:arrow-right" />
    </a>
  </div>
  <div class="code">
    <CoreLibCodePreview client:load />
  </div>
</section>

<style>
  .core-lib {
    display: flex;
    gap: var(--spacing-24);
    flex-direction: column;
    justify-content: space-between;
    padding-block: var(--spacing-64);
    background-color: var(--color-neutral-950);
    color: var(--color-neutral-50);

    .info {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: var(--spacing-40);

      a {
        width: fit-content;

        svg {
          --size: 20px;

          height: var(--size);
          width: var(--size);
          transition: translate 200ms ease;
        }

        &:hover svg {
          translate: 4px 0;
        }
      }

      .main-action {
        display: flex;
        align-items: center;
        gap: var(--spacing-8);
        font: var(--label-lg);
        color: var(--color-neutral-50);
        width: fit-content;

        svg {
          --size: 20px;

          height: var(--size);
          width: var(--size);
          transition: translate 200ms ease;
        }

        &:hover svg {
          translate: 4px 0;
        }
      }
    }

    .code {
      width: 100%;
    }

    .info,
    .code {
      max-width: 100%;
    }

    @media (width >= 88rem) {
      flex-direction: row;

      .info,
      .code {
        max-width: 600px;
      }
    }
  }
</style>
